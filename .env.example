# ── Active Provider ───────────────────────────────────────────────────────────
# Options: groq | gemini | claude
AI_PROVIDER=groq

# ── Groq (free, 14,400 req/day) ───────────────────────────────────────────────
# Get key: https://console.groq.com
GROQ_API_KEY=

# ── Gemini (free tier — may be regionally blocked) ────────────────────────────
# Get key: https://aistudio.google.com
GEMINI_API_KEY=

# ── Claude / Anthropic (paid — ~$0.003 per call) ──────────────────────────────
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=
